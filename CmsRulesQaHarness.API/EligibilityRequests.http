  "monthlyIncome": 2200,
  "isDisabled": true,
  "isPregnant": false,
  "isBlind": false,
  "householdSize": 1
}

### Negative Test: No qualifying category
POST {{CmsRulesQaHarness.API.BaseUrl}}/api/Eligibility/determine
Content-Type: application/json

{
  "age": 30,
  "monthlyIncome": 800,
  "isDisabled": false,
  "isPregnant": false,
  "isBlind": false,
  "householdSize": 1
}

### Edge Test: Applicant exactly age 65 qualifies
POST {{CmsRulesQaHarness.API.BaseUrl}}/api/Eligibility/determine
Content-Type: application/json

{
  "age": 65,
  "monthlyIncome": 1500,
  "isDisabled": false,
  "isPregnant": false,
  "isBlind": false,
  "householdSize": 1
}

### Edge Test: Aged applicant exactly at income limit qualifies
POST {{CmsRulesQaHarness.API.BaseUrl}}/api/Eligibility/determine
Content-Type: application/json

{
  "age": 70,
  "monthlyIncome": 1600,
  "isDisabled": false,
  "isPregnant": false,
  "isBlind": false,
  "householdSize": 1
}

### Edge Test: Aged applicant one dollar over income limit does not qualify
POST {{CmsRulesQaHarness.API.BaseUrl}}/api/Eligibility/determine
Content-Type: application/json

{
  "age": 70,
  "monthlyIncome": 1601,
  "isDisabled": false,
  "isPregnant": false,
  "isBlind": false,
  "householdSize": 1
}

### Edge Test: Disabled applicant exactly at income limit qualifies
