@CmsRulesQaHarness.API.BaseUrl = https://localhost:7081

###############################################################################
# JSON FORMAT TESTS
###############################################################################

POST {{CmsRulesQaHarness.API.BaseUrl}}/api/Eligibility/determine
Content-Type: application/json
{
  "age": 67,
  "monthlyIncome": 1200,
  "isDisabled": false,
  "isPregnant": false,
  "isBlind": false,
  "householdSize": 1
}

### Positive Test: Aged applicant qualifies
POST {{CmsRulesQaHarness.API.BaseUrl}}/api/Eligibility/determine
Content-Type: application/json

{
  "age": 67,
  "monthlyIncome": 1200,
  "isDisabled": false,
  "isPregnant": false,
  "isBlind": false,
  "householdSize": 1
}

### Positive Test: Disabled applicant qualifies
POST {{CmsRulesQaHarness.API.BaseUrl}}/api/Eligibility/determine
Content-Type: application/json

{
  "age": 42,
  "monthlyIncome": 1700,
  "isDisabled": true,
  "isPregnant": false,
  "isBlind": false,
  "householdSize": 1
}

### Positive Test: Blind applicant qualifies
POST {{CmsRulesQaHarness.API.BaseUrl}}/api/Eligibility/determine
Content-Type: application/json

{
  "age": 35,
  "monthlyIncome": 1500,
  "isDisabled": false,
  "isPregnant": false,
  "isBlind": true,
  "householdSize": 1
}

### Negative Test: Aged applicant income too high
POST {{CmsRulesQaHarness.API.BaseUrl}}/api/Eligibility/determine
Content-Type: application/json

{
  "age": 67,
  "monthlyIncome": 2500,
  "isDisabled": false,
